<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reja</title>
    <link
      rel="stylesheet"
      href="https://stackpath.bootstrapcdn.com/bootstrap/4.2.1/css/bootstrap.min.css"
      integrity="sha384-GJzZqFGwb1QTTN6wy59ffF1BuGJpLSa9DkKMp0DgiMDm4iYMj70gZWKYbI706tWS"
      crossorigin="anonymous"
    />
  </head>
  <body style="background-color: #b8bbd1">
    <div class="container">
      <h1 class="text-center mb-4">Plan and Goals</h1>

      <div class="jumbotron p-3 shadow-sm">
        <form id="create-form" action="/create-item" method="POST">
          <div class="d-flex align-items-center">
            <input
              id="create-field"
              type="text"
              autofocus
              autocomplete="off"
              class="form-control mr-3"
              name="reja"
              style="flex: 1"
            />
            <button class=" btn btn-primary" style="border-radius: 20px">
             Add new plan
            </button>
          </div>
        </form>

        <div class="card-body">
        
          <ul class="list-group" id="item-list">
          <% items.map(function(item){ %>
   <li 
   class="list-group-item list-group-item-info d-flex align-items-center justify-content-between">
  <span class="item-text"><%=item.reja%></span>
  <div>
    <button  data-id="<%=item._id%>" class="edit-me btn btn-secondary btn-sm mr-1" >Edit</button>
    <button style="background-color: red; color: white;" data-id="<%=item._id%>" class="delete-me btn btn-denger btn-sm">Delete</button>
</li>
          <% }) %>
          </ul>
            <button style= "  margin-top: 20px; border-radius:   15px ; border: none; background-color: red ; "><span style="color: white;">Delete all plans</span></button>
          <!-- <p><strong>Delete</strong></p> -->
        </div>
      </div>
    </div>
    <script src="/browser.js"></script>
    <script src="https://unpkg.com/axios/dist/axios.min.js"></script>
  </body>
</html>